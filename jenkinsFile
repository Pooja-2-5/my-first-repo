pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/Pooja-2-5/myRepo.git'
            }
        }
        stage('Publish') {
            steps{
           publishHTML([

            allowMissing: true,
            alwaysLinkToLastBuild: false,
            keepAll: false,
            reportDir : '.',
            reportFiles : 'sort.html',
            reportName : 'hii'
            ])
            }
        }
}
}
